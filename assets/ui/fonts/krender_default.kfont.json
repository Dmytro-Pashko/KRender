    "spacing": 1,
    "pageWidth": 512,
    "pageHeight": 256,
    "antialias": true,
    "hinting": true,
    "rasterizer": "AWT",
    "textAntialiasing": "LCD_HBGR",
    "fractionalMetrics": true,
    "renderQuality": "QUALITY",
    "strokeControl": "DEFAULT"
  }
}
