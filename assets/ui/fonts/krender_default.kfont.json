{
  "format": "krender.bitmapFont",
  "version": 1,
  "sourceFont": "fonts/roboto.ttf",
  "outputFnt": "ui/fonts/krender_default.fnt",
  "outputPages": [
    "ui/fonts/krender_default.png"
  ],
  "generation": {
    "sizePx": 24,
    "charsetPreset": "ENGLISH_SYMBOLS_UKRAINIAN_CYRILLIC",
